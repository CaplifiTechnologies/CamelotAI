# CamelotAI — copy to `.env` for the personal build. NEVER commit `.env`.
# Paid seats are optional; the app runs free in Local Only mode without any keys.
#
# Secrets resolve in this order (first wins), so `.env` is rarely needed:
#   ANTHROPIC_API_KEY → env → macOS Keychain (service "ANTHROPIC_API_KEY")
#   xAI/Grok          → env XAI_API_KEY → Keychain "XAI_API_KEY" → ~/.grok/auth.json (Grok CLI login)
#   Sakana Fugu       → env SAKANA_API_KEY → Keychain "SAKANA_API_KEY" (Council @fugu guest only)

# Persistence (SQLite via Prisma)
# Dev: relative path under prisma/. Packaged app uses ~/Library/Application Support/CamelotAI/camelot.db automatically.
DATABASE_URL="file:./prisma/dev.db"

# Local free seat (Ollama) — no key needed
OLLAMA_BASE_URL="http://localhost:11434"
CAMELOT_TALLY_MODEL="qwen2.5:7b"

# Dev chat routing logs (seat, threadId, history length)
# CAMELOT_DEV_LOG="1"

# Extra allowed roots for Electron fs bridge (colon-separated on macOS)
# CAMELOT_FS_ROOTS=""

# Optional model overrides
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# GROK_MODEL="grok-4.3"
# GROK_AUTH_JSON="~/.grok/auth.json"
# FUGU_MODEL="fugu"          # or fugu-ultra for hard council calls
# FUGU_TIMEOUT_MS="120000"   # increase for fugu-ultra (default 300000 when model name includes ultra)
# Agentic layer (ARMED OFF — mirror ~/ALMI/fugu_config.yaml enabled: false)
# FUGU_AGENTIC_ENABLED="false"
# FUGU_RESPONSES_API="true"
# FUGU_STREAMING="true"
# FUGU_WEB_SEARCH="true"
# FUGU_ULTRA="true"
# FUGU_ULTRA_MODEL="fugu-ultra"
# FUGU_ULTRA_TIMEOUT_MS="300000"

# Paid seats — prefer the Keychain; leave blank here to keep secrets out of files.
ANTHROPIC_API_KEY=""
XAI_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
SAKANA_API_KEY=""
